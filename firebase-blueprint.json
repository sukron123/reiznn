{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and account information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "balance": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Game account or top-up package",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string", "enum": ["account", "topup"] },
        "game": { "type": "string" },
        "price": { "type": "number" },
        "stock": { "type": "number" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "category", "price", "isActive"]
    },
    "Order": {
      "title": "Order",
      "description": "Transaction record for game accounts or top-ups",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "completed", "failed", "cancelled"] },
        "paymentMethod": { "type": "string" },
        "gameId": { "type": "string", "description": "Target game ID for top-up" },
        "details": { "type": "string", "description": "Account details for account sales" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "productId", "amount", "status", "createdAt"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "Real-time support message",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "chatId": { "type": "string", "description": "userId or specific ticketId" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["chatId", "senderId", "text", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Internal user profile"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Available product listing"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Transaction History"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Support messages for a user"
    }
  }
}
